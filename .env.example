# ============================================
# SURAKSHA V2 — Environment Variables
# Copy this file to .env and fill in real keys
# All keys are OPTIONAL — app runs in mock mode without them
# ============================================

# Google Gemini AI (for AI Assistant)
# Get key at: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Google Maps JavaScript SDK
# Get key at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_KEY=

# Twilio SMS (for SOS text alerts)
# Get credentials at: https://www.twilio.com/console
VITE_TWILIO_ACCOUNT_SID=
VITE_TWILIO_AUTH_TOKEN=
VITE_TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# SendGrid Email (for SOS email alerts)
# Get key at: https://app.sendgrid.com/settings/api_keys
VITE_SENDGRID_API_KEY=
VITE_SENDGRID_FROM_EMAIL=alerts@suraksha.app
